@baseUrl = http://localhost:8000/api
@token = YOUR_TOKEN_HERE

### 1. Buat Toko Baru (Shop)
# Karena sistem kita multi-tenant, kita butuh ID Toko dulu.
POST {{baseUrl}}/shop
Content-Type: application/json

{
    "name": "Toko Kopi Kenangan",
    "address": "Jl. Merdeka No. 10"
}

### 2. Registrasi User (Owner)
# Gunakan shop_id dari hasil langkah 1
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "name": "Ansori",
    "email": "ansori@example.com",
    "password": "password123",
    "password_confirmation": "password123",
    "role": "owner",
    "shop_id": 1
}

### 3. Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "ansori@example.com",
    "password": "password123"
}

### 4. Cek User Login (Gunakan Token dari Langkah 3)
GET {{baseUrl}}/user
Authorization: Bearer {{token}}
Accept: application/json

### 5. Tambah Kategori
POST {{baseUrl}}/categories
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
    "name": "Minuman Kopi"
}

### 6. Tambah Produk
# Catatan: Untuk upload file asli di REST Client agak kompleks, 
# sementara bisa test tanpa gambar dulu jika model mengizinkan, 
# atau gunakan Postman untuk testing upload file.
POST {{baseUrl}}/products
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
    "category_id": 1,
    "name": "Cappuccino",
    "price": 25000,
    "stock": 100,
    "sku": "KOPI-001"
}

### 7. Buat Transaksi (Order)
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
    "payment_method": "cash",
    "paid_amount": 50000,
    "customer_name": "Budi",
    "items": [
        {
            "product_id": 1,
            "quantity": 2
        }
    ]
}

### 8. Laporan Penjualan
GET {{baseUrl}}/reports/summary
Authorization: Bearer {{token}}
Accept: application/json
